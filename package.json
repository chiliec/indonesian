{
  "name": "indonesian-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Indonesian-for-English Telegram conversation coach for Bali expats.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "tsx --test 'test/**/*.test.ts'",
    "prep:anki": "tsx scripts/prep-anki.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@deepgram/sdk": "^3.9.0",
    "@google-cloud/text-to-speech": "^5.6.0",
    "@typegoose/typegoose": "^12.10.1",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "mongoose": "^8.8.3",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0",
    "mongodb-memory-server": "^11.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
